# Network
NETWORK_NAME=sigma-bb-network

# Postgres Root
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=SASA
POSTGRES_DB=sigma_db

# Postgres host/port used by services
POSTGRES_HOST=postgres17
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_MGMT_HOST_PORT=15672

# Sigma / ports
SIGMA_PORT=8100
SIGMA_HOST_PORT=8100